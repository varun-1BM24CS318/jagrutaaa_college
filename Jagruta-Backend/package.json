{
  "name": "jagruta-backend",
  "version": "1.0.0",
  "main": "src/index.ts",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "seed": "ts-node src/seed.ts",
    "import:elections": "ts-node src/importElectionResults.ts",
    "import:representatives": "ts-node src/importRepresentatives.ts",
    "import:wards": "ts-node src/importWardData.ts",
    "import:complaints": "ts-node src/importComplaints.ts",
    "import:manifesto": "ts-node src/importManifesto.ts",
    "import:calendar": "ts-node src/importElectionCalendar.ts",
    "import:assets": "ts-node src/importAssetGrowth.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "@trpc/server": "11.17.0",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.18.2",
    "openai": "4.80.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "22.10.7",
    "nodemon": "3.1.9",
    "prisma": "^5.22.0",
    "ts-node": "10.9.2",
    "typescript": "5.7.3"
  }
}
